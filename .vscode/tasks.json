{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure (debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "debug-gnu-arm"
            ],
        },
        {
            "label": "build (debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "debug-gnu-arm"
            ],
            "problemMatcher": "$gcc"
        },
        {
            "label": "build (debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "debug-gnu-arm"
            ],
            "problemMatcher": "$gcc"
        }
    ]
}